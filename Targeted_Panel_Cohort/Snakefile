#                "--read-group-id={params.id}"

rule get_consensus_unmapped_bam:
        input: expand(BAM_DIR + "/{sample}_ss_consensus.unmapped.bam", sample = SAMPLES)

#----------------------------------------------------------------------
# C.4 Align collapsed families
# After you have generated collapsed single read families, you must remap the reads and merge mapped/unmapped BAMs to retain the appropriate metadata in the mapped file.
# The mapping procedure is the same for raw reads described previously
#----------------------------------------------------------------------
rule order_sort_bam:
        input: BAM_DIR + "/{sample}_ss_consensus.unmapped.bam"
        output: BAM_DIR+ "/{sample}_ss_consensus.tmp.unmapped.bam"
        resources:
                mem_mb=30000
        params:
                java = config["software"]["java"],
                picard_jar = config["software"]["picard_jar"]
        log: "logs/bwa_SS_UMI.sort_bam/{sample}.log"
        shell:
                "{params.java} -Xmx32G -jar {params.picard_jar} SortSam I={input} O={output} SORT_ORDER=queryname"

rule bam_SS_UMI_remap_consensus_reads:
        input: BAM_DIR + "/{sample}_ss_consensus.tmp.unmapped.bam"
        output: BAM_DIR + "/{sample}_ss_consensus.mapped.bam"
        resources:
                mem_mb=30000
        params:
                java = config["software"]["java"],
                picard_jar = config["software"]["picard_jar"],
                bwa = config["software"]["bwa"],
                ref = config["reference"]["hg19"]["ref_fa"]
        log: "logs/bwa_SS_UMI.remap_consensus_reads/{sample}.log"
        shell:
                "{params.java} -Xmx32G -jar {params.picard_jar} SamToFastq "
                "I={input} F=/dev/stdout INTERLEAVE=true "
                "| {params.bwa} mem -p -t 8 {params.ref} /dev/stdin "
                "| {params.java} -Xmx32G -jar {params.picard_jar} SortSam I=/dev/stdin O=/dev/stdout SORT_ORDER=queryname"
                "| {params.java} -Xmx32G -jar {params.picard_jar} MergeBamAlignment "
                "UNMAPPED={input} ALIGNED=/dev/stdin "
                "O={output} R={params.ref} "
                "SO=coordinate ALIGNER_PROPER_PAIR_FLAGS=true MAX_GAPS=-1 "
                "ORIENTATIONS=FR VALIDATION_STRINGENCY=SILENT CREATE_INDEX=true"

rule get_consensus_mapped_bam:
        input: expand(BAM_DIR + "/{sample}_ss_consensus.mapped.bam", sample = SAMPLES)

#----------------------------------------------------------------------
# C.5. Filter collapsed families
#----------------------------------------------------------------------
rule bam_SS_UMI_filter_consensus_reads:
        input: BAM_DIR + "/{sample}_ss_consensus.mapped.bam"
        output: BAM_DIR + "/{sample}_ss_consensus.mapped.umi_filtered.bam"
        params:
                fgbio_jar = config["software"]["fgbio_jar"],
                java = config["software"]["java"],
                ref = config["reference"]["hg19"]["ref_fa"],
                samtools = config["software"]["samtools"]
        log: "logs/bwa_SS_UMI.filter_consensus_reads/{sample}.log"
        shell:
                "{params.samtools} sort -n -u {input} | "
                "{params.java} -Xmx16G -jar {params.fgbio_jar} FilterConsensusReads "
                "--input=/dev/stdin "
                "--output={output} "
                "--ref={params.ref} "
                "--min-reads=1 --max-read-error-rate=0.05 --max-base-error-rate=0.1 --min-base-quality=40 --max-no-calls=0.1"

rule get_consensus_mapped_filtered_bam:
        input: expand(BAM_DIR + "/{sample}_ss_consensus.mapped.umi_filtered.bam", sample = SAMPLES)

rule cnvkit:
	input:
		"cnvkit/merged/merged_heatmap.pdf",
		"cnvkit/merged/segmentation_files.seg",
		expand("cnvkit/genemetrics/segment/{tumor_sample}_mapped.markdup_UMI.txt",tumor_sample = TUMOR_SAMPLES),
		expand("cnvkit/genemetrics/gene/{tumor_sample}_mapped.markdup_UMI.txt",tumor_sample = TUMOR_SAMPLES),
		expand("cnvkit/scatter/{tumor_sample}_scatter_mapped.markdup_UMI.pdf",tumor_sample = TUMOR_SAMPLES),
        	expand("cnvkit/scatter_chr17/{tumor_sample}_scatter_chr17_mapped.markdup_UMI.pdf",tumor_sample = TUMOR_SAMPLES)
			

rule run_cnvkit_batch:
        input:
                tumor_bams = expand(BAM_DIR + "/{sample}_mapped.markdup_UMI.bam", sample = TUMOR_SAMPLES),
                normal_bams = expand(BAM_DIR + "/{normal_sample}_mapped.markdup_UMI.bam", normal_sample = SAMPLE_PAIRS.values())
        output: expand("cnvkit/{sample}_mapped.markdup_UMI.{filetype}",sample = TUMOR_SAMPLES,filetype = ["cns","cnr"])
        params:
                cnvkit = config["software"]["cnvkit"],
                access = config["reference"]["hg19"]["cnvkit_access"],
                targets = config["targets_file"],
                fasta = config["reference"]["hg19"]["ref_fa"],
                refFlat = config["reference"]["hg19"]["refFlat"]
	log: "logs/cnvkit/all_run_cnvkit.log"
        threads: 8
        shell:
                "{params.cnvkit} batch {input.tumor_bams} --normal {input.normal_bams} --targets {params.targets} --fasta {params.fasta} --access {params.access} --annotate {params.refFlat} --processes {threads} --output-reference cnvkit/normal_reference.cnn --scatter --diagram  --output-dir cnvkit/ &> {log}"

rule run_cnvkit_call:
        input: "cnvkit/{sample}_mapped.markdup_UMI.cns"
        output: "cnvkit/{sample}_mapped.markdup_UMI.call.cns"
        params:
                cnvkit = config["software"]["cnvkit"]
        log: "logs/cnvkit/call/{sample}.log"
        shell:
                "{params.cnvkit} call {input} -o {output} &> {log}"

rule get_CNVs:
        input: expand("cnvkit/{sample}_mapped.markdup_UMI.{filetype}", sample = TUMOR_SAMPLES, filetype = ["cns","call.cns"])

rule run_cnvkit_scatter:
        input:
                cnr = "cnvkit/{tumor_sample}_mapped.markdup_UMI.cnr",
                cns = "cnvkit/{tumor_sample}_mapped.markdup_UMI.cns"

#----------------------------------------------------------------------
# **VARIANT CALLING**  
#----------------------------------------------------------------------
#----------------------------------------------------------------------
# Clip overlap between read pairs
#----------------------------------------------------------------------
# Updated filename to output {}.unsorted.bam since this file is not order sorted
# Added in a new rule "sort_clipped_bam" to sort the resultant file
rule bam_SS_UMI_clip_bam:
        input: BAM_DIR + "/{sample}_ss_consensus.mapped.umi_filtered.bam"
        output: BAM_DIR + "/{sample}_ss_consensus.mapped.filtered.clipped.unsorted.bam"
        params:
                fgbio_jar = config["software"]["fgbio_jar"],
                java = config["software"]["java"],
                ref = config["reference"]["hg19"]["ref_fa"]
        log: "logs/bwa_SS_UMI.clip_bam/{sample}.log"
        shell:
                "{params.java} -Xmx16G -jar {params.fgbio_jar} ClipBam "
                "--input={input} "
                "--output={output} "
                "--ref={params.ref} "
                "--upgrade-clipping=false --clip-overlapping-reads=true"

rule sort_clipped_bam:
        input: BAM_DIR + "/{sample}_ss_consensus.mapped.filtered.clipped.unsorted.bam"
        output: BAM_DIR + "/{sample}_ss_consensus.mapped.filtered.clipped.bam"
        params:
                samtools = config["software"]["samtools"]
        log: "logs/sort_bam/{sample}.log"
        shell:
                "{params.samtools} sort -o {output} {input} &> {log}"


rule get_clipped_bam_SS_UMI:
        input: expand(BAM_DIR + "/{sample}_ss_consensus.mapped.filtered.clipped.bam.bai", sample = SAMPLES)


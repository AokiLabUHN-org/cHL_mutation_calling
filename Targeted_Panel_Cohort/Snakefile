##
###BedToIntervalList (Picard)
###<https://gatk.broadinstitute.org/hc/en-us/articles/360036883931-BedToIntervalList-Picard->
### Converts a BED file to a Picard Interval List. This tool provides easy conversion from BED to the Picard interval_list format which is required by many Picard processing tools. Note that the coordinate system of BED files is such that the first base or position in a sequence is numbered "0", while in interval_list files it is numbered "1".
###
#

rule create_interval_list:
	#possible alternative?
	#input: "/cluster/projects/aokigroup/Stueckmann/input/hg37/somatic-b37_whole_exome_agilent_1.1_refseq_plus_3_boosters.Homo_sapiens_assembly19.targets.interval_list"
        #hard-coding input to what I assumed Gerben used for now
	#copied access-5k-mappable.hg19.bed, renamed to intervals.hg19.bed for combat.
        input: "data/intervals.hg19.bed"
        output:"data/interval_list.txt"
        params:
                java = config["software"]["java"],
                picard_jar = config["software"]["picard_jar"],
                SD = "data/reference_hg19.dict"
        shell:
                "{params.java} -jar {params.picard_jar} BedToIntervalList "
                "I={input} "
                "O={output} "
                "SD={params.SD}"

rule create_matching_ref:
    input:
        ref=config["reference"]["hg19"]["ref_fa"],
        order="bam.contig_order.txt"
    output:
        fasta="data/hg19.fa",
        fai="data/hg19.fa.fai",
        dict="data/reference_hg19.dict"
    params:
        java=config["software"]["java"],
        picard_jar=config["software"]["picard_jar"]
    shell:
        """
        samtools faidx {input.ref} $(cat {input.order}) > {output.fasta}
        samtools faidx {output.fasta}
        {params.java} -Xmx4g -jar {params.picard_jar} CreateSequenceDictionary \
            R={output.fasta} \
            O={output.dict}
        """

# IDT workflow: <https://www.idtdna.com/pages/products/next-generation-sequencing/library-preparation/xgen-prism-library-prep-kit?utm_source=google&utm_medium=cpc&utm_campaign=ga_lib_prep&utm_content=ad_group_lib_prep&gclid=CjwKCAjw07qDBhBxEiwA6pPbHv8psmCYHn2fupMN5H3qgKMathc1mhzvVSPe6nxB5gVZFQDempq5txoCSD8QAvD_BwE>
# <xgen-prism-dna-library-prep-kit-processing-sequencing-data-with-umis.pdf>


# ------------------------------------------------
# Prepare sequencing reads
# -------------------------------------
# When start_from_mapped_bam is false (default): FASTQ → unaligned BAM →
# UMI tags → bam_UMI_align_reads → mapped BAM.
# When true: omit those rules; place {sample}_mapped.bam under bam_dir on disk
# for every sample in sample_file before running the workflow.
# -------------------------------------
if not START_FROM_MAPPED_BAM:
    # --------------------------------------------------
    # 1. Construct an unmapped BAM
    # Using a demultiplexed FASTQ file, generate an unmapped BAM with FastqToSam (Picard)
    # -----------------------------------------------------
    rule bam_UMI_fastq_to_sam:
            input:
                    fq1 = "../fastq/{sample}.1.fastq.gz",
                    fq2 = "../fastq/{sample}.2.fastq.gz"
            output: BAM_DIR + "/{sample}_unaligned.bam"
            params:
                    java = config["software"]["java"],
                    picard_jar = config["software"]["picard_jar"],
                    id = "{sample}"
            log:
                    "logs/bam_UMI.fastq_to_sam/{sample}.log"
            shell:
                    "{params.java} -jar {params.picard_jar} FastqToSam "
                    "O={output} "
                    "F1={input.fq1} F2={input.fq2} "
                    "SM={params.id} LB={params.id} PU=unit1 PL=illumina"

    rule get_unaligned_bam:
            input: expand(BAM_DIR + "/{sample}_unaligned.bam", sample = SAMPLES)

    # -----------------------------------------------------------
    # 2. Extract UMIs and add to the RX tag
    # ExtractUmisFromBam (fgbio) processes unmapped BAM files, extracting in-line UMIs contained within read 1 or read 2 sequences and adds them to into the RX tag
    # -------------------------------------------------------------
    rule bam_UMI_extract_UMIs:
            input: BAM_DIR + "/{sample}_unaligned.bam"
            output: BAM_DIR + "/{sample}_unaligned_umi.bam"
            params:
                    java = config["software"]["java"],
                    fgbio_jar = config["software"]["fgbio_jar"]
            log: "logs/bam_UMI.extract_UMIs/{sample}.log"
            shell:
                    "{params.java} -jar {params.fgbio_jar} ExtractUmisFromBam "
                    "--input={input} "
                    "--output={output} "
                    "--read-structure 3M2S146T 3M2S146T --molecular-index-tags ZA ZB --single-tag=RX"

    rule get_unaligned_umi_bam:
            input: expand(BAM_DIR + "/{sample}_unaligned_umi.bam", sample = SAMPLES)

    #---------------------------------------------------------------------
    # 3. Align reads
    # When you have an unmapped BAM file with RX tags, use a combination of an aligner and MergeBamAlignment (Picard) to generate a mapped BAM that includes all necessary metadata including the UMIs.
    # note: MergeBamAlignemnet requires the unmapped BAM file to be in "queryname" sort order. In this cases, the BAM file output by ExtractUmisFromBam is already in the correct sort order
    # -------------------------------------------------------------------
    rule bam_UMI_align_reads:
            input: BAM_DIR + "/{sample}_unaligned_umi.bam"
            output: BAM_DIR + "/{sample}_mapped.bam"
            params:
                    java = config["software"]["java"],
                    picard_jar = config["software"]["picard_jar"],
                    bwa = config["software"]["bwa"],
                    ref = config["reference"]["hg19"]["ref_fa"]
            log: "logs/bam_UMI.align_reads/{sample}.log"
            shell:
                    "{params.java} -jar {params.picard_jar} SamToFastq "
                    "I={input} F=/dev/stdout INTERLEAVE=true "
                    "| {params.bwa} mem -p -t 8 {params.ref} /dev/stdin "
                    "| {params.java} -jar {params.picard_jar} MergeBamAlignment "
                    "UNMAPPED={input} ALIGNED=/dev/stdin "
                    "O={output} R={params.ref} "
                    "SO=coordinate ALIGNER_PROPER_PAIR_FLAGS=true MAX_GAPS=-1 "
                    "ORIENTATIONS=FR VALIDATION_STRINGENCY=SILENT CREATE_INDEX=true"

rule get_bam_UMI_aligned: 
        input: expand(BAM_DIR + "/{sample}_mapped.bam", sample = SAMPLES)
#------------------------------------------------------------------------
# **Deduplication or error correction ** 
# A. Deduplicate by start-stop position
# B. Deduplicate by UMI
# C. Error correction by collapsing single read families
# D. Error correction by collapsing combined read families
#--------------------------------------------------------------------------


#----------------------------------------------------------------------
# A.Deduplicate by start-stop position 
#----------------------------------------------------------------------
rule markdup_bam:
        input: BAM_DIR_INPUT + "/{sample}_mapped.bam"
        output:
                bam = BAM_DIR + "/{sample}_mapped.markdup.bam",
                metrics = "metrics/{sample}.dup_metrics"
        params:
                java = config["software"]["java"],
                picard_jar = config["software"]["picard_jar"]
        log: "logs/markdup_bam/{sample}.log"
        shell:
                                "{params.java} -Xmx4g -jar {params.picard_jar} MarkDuplicates I={input} O={output.bam}  M={output.metrics} &> {log}"

rule dedupl_start_stop:
	input:expand(BAM_DIR + "/{sample}_mapped.markdup.bam",sample = SAMPLES)


#----------------------------------------------------------------------
# B. Deduplicate by UMI
#---------------------------------------------------------------------
rule markdup_UMI_bam:
        input: BAM_DIR_INPUT + "/{sample}_mapped.bam"
        output:
                bam = BAM_DIR + "/{sample}_mapped.markdup_UMI.bam",
                metrics = "metrics/{sample}.dup_UMI.metrics"
        params:
                java = config["software"]["java"],
                picard_jar = config["software"]["picard_jar"]
        log: "logs/markdup_UMI_bam/{sample}.log"
        shell:
                "{params.java} -Xmx4g -jar {params.picard_jar} MarkDuplicates I={input} O={output.bam} BARCODE_TAG=RX  M={output.metrics} &> {log}"

rule dedupl_UMI:
	input:expand(BAM_DIR + "/{sample}_mapped.markdup_UMI.bam",sample = SAMPLES)

#----------------------------------------------------------------------
# C/D.2 Group read families
# -----------------------------------------------------------------
rule bam_UMI_group_reads_by_UMI:
        input: BAM_DIR_INPUT + "/{sample}_mapped.bam"
        output: BAM_DIR + "/{sample}_groupedUMI.bam"
        params:
                java = config["software"]["java"],
                fgbio_jar = config["software"]["fgbio_jar"],
		histo = "histograms/{sample}_histogram_family_size.tsv"
        log: "logs/bam_UMI.group_reads_by_UMI/{sample}.log"
        shell:
                "{params.java} -Xmx16G -jar {params.fgbio_jar} GroupReadsByUmi "
                "--input={input} "
                "--output={output} "
                "--strategy=paired --min-map-q=20 --edits=1 --family-size-histogram={params.histo}"

rule get_groupedUMI_bam:
        input: expand(BAM_DIR + "/{sample}_groupedUMI.bam", sample = SAMPLES)

#----------------------------------------------------------------------
# C. Error correction by collapsing single read families
#----------------------------------------------------------------------

#----------------------------------------------------------------------
# C.3. Collapse single read families
# by combining each set of reads using CallMolecularConsensusReads (fgbio)
## This step generates collapsed single read families as an unmaped BAM from the output of GroupReadsByUMI
#Updated to use paired info and group reads by Duplex consensus rather than SSCS
#Commented out old rule from Gerben
#----------------------------------------------------------------------
rule bam_SS_UMI_generate_consensus_reads:
        input: BAM_DIR + "/{sample}_groupedUMI.bam"
        output:
                output=BAM_DIR + "/{sample}_ss_consensus.unmapped.bam",
                rejects=BAM_DIR + "/{sample}_ss_consensus.rejects.bam"
        params:
                java = config["software"]["java"],
                fgbio_jar = config["software"]["fgbio_jar"],
                id = "{sample}"
        log: "logs/bwa_SS_UMI.generate_consensus_reads/{sample}.log"
        shell:
                "{params.java} -Xmx16G -jar {params.fgbio_jar} CallMolecularConsensusReads "
                "--input={input} "
                "--output={output.output} "
                "--rejects={output.rejects} "
                "--min-input-base-quality=20 --min-reads=1 "
                "--read-group-id={params.id}"

#Not enough coverage to use the duplex consensus read calling
#"{params.java} -Xmx16G -jar {params.fgbio_jar} CallDuplexConsensusReads "


#----------------------------------------------------------------------
# Tumour-only variant calling with Mutect2 (GATK)
#----------------------------------------------------------------------
rule run_Mutect2_tumourOnly:
        input:
                bam = BAM_DIR + "/{sample}_ss_consensus.mapped.filtered.clipped.bam",
                bai = BAM_DIR + "/{sample}_ss_consensus.mapped.filtered.clipped.bam.bai"
        output:
                vcf = "mutect2/{sample}/{sample}.tumourOnly.vcf.gz",
                stats = "mutect2/{sample}/{sample}.tumourOnly.vcf.gz.stats"
        params:
                gatk = config["software"]["gatk"],
                ref = config["reference"]["hg19"]["ref_fa"],
                pon = config["reference"]["hg19"]["pon"],
                intervals = config["mutect_intervals_file"]
        log: "logs/mutect2/{sample}.tumourOnly.log"
        shell:
                "{params.gatk} Mutect2 "
                "-R {params.ref} "
                "-I {input.bam} "
                "-L {params.intervals} "
                "--interval-padding 100 "
                "-O {output.vcf} "
                "&> {log}"

#"--panel-of-normals {params.pon} "

rule get_Mutect2_tumourOnly:
        input: expand("mutect2/{sample}/{sample}.tumourOnly.vcf.gz.stats", sample = SAMPLES)

#----------------------------------------------------------------------
# Mutect2 variant filtering (GATK)
#----------------------------------------------------------------------
rule run_Mutect2_filtering:
        input:
                vcf = "mutect2/{sample}/{sample}.tumourOnly.vcf.gz"
        output:
                vcf_out = "mutect2/{sample}/{sample}.tumourOnly.filtered.vcf.gz"
        params:
                gatk = config["software"]["gatk"],
                ref = config["reference"]["hg19"]["ref_fa"]
        log: "logs/mutect2filtering/{sample}.tumourOnly.log"
        shell:
                "{params.gatk} FilterMutectCalls "
                "-R {params.ref} "
                "-V {input.vcf} "
                "-O {output.vcf_out} "
                "&> {log}"


rule get_Mutect2_filtered:
        input: expand("mutect2/{sample}/{sample}.tumourOnly.filtered.vcf.gz", sample = SAMPLES)

#----------------------------------------------------------------------
# Mutect2 annotation (funcotator)
#----------------------------------------------------------------------
rule run_funcotator:
        input:
                vcf = "mutect2/{sample}/{sample}.tumourOnly.filtered.vcf.gz"
        output:
                vcf_out = "mutect2/{sample}/{sample}.tumourOnly.funcotated.vcf.gz"
        params:
                gatk = config["software"]["gatk"],
                ref = config["reference"]["hg19"]["ref_fa"],
                func_source = config["software"]["funcotator"]
        log: "logs/funcotator/{sample}.tumourOnly.log"
        shell:
                "{params.gatk} Funcotator "
                "-R {params.ref} "
                "-V {input.vcf} "
                "-O {output.vcf_out} "
                "--output-file-format VCF "
                "--data-sources-path {params.func_source} "
                "--ref-version hg19 "
                "&> {log}"


rule get_Funcotator:
        input: expand("mutect2/{sample}/{sample}.tumourOnly.funcotated.vcf.gz", sample = SAMPLES)
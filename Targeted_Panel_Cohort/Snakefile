        params:
                cnvkit = config["software"]["cnvkit"]
        log: "logs/cnvkit/scatter/{tumor_sample}_scatter_mapped.markdup_UMI.log"
        shell:
                "{params.cnvkit} scatter {input.cnr} -s {input.cns} --output {output} &> {log}"


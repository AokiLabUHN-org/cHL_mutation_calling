# QC 
# --------------------------------------------------------------
rule picard_QC_UMI_start_stop:
        input:
                "metrics/all.alignment_summary_metrics.pair.txt",
                "metrics/all.insert_size_metrics.txt",
                "metrics/all.hs_metrics_UMI_markdup.txt",
                expand("metrics/{sample}_UMI_markdup.flagstats", sample = SAMPLES)
# --------------------------------------------------------------

rule merge_alignment_summary_UMI_start_stop:
        input: expand("metrics/{sample}.alignment_summary_metrics", sample = SAMPLES)
        output: "metrics/all.alignment_summary_metrics.pair.txt"
        shell:
                """
                grep -v '#' {input[0]} | sed '/^$/d' | head -n 1 | cut -f 2- > {output}.header &&
                for file in {input}; do
                        grep -v '#' ${{file}} | sed '/^$/d' | tail -n 1 | cut -f 2- >> {output}.tmp;
                done
                echo {SAMPLES} | sed 's/ /\\n/g' | paste - {output}.tmp > {output} &&
                echo -e 'sampleID' | paste - {output}.header | cat - {output} > {output}.tmp &&
                mv {output}.tmp {output} && rm {output}.header
                """

rule merge_insert_metrics_UMI_start_stop:
        input: expand("metrics/{sample}.insert_size_metrics", sample = SAMPLES)
        output: "metrics/all.insert_size_metrics.txt"
        shell:
                """
                awk 'NR == 7' {input[0]} > {output}.header;
                for file in {input}; do
                        awk 'NR == 8' ${{file}} >> {output}.tmp;
                done
                echo {SAMPLES} | sed 's/ /\\n/g' | paste - {output}.tmp > {output} &&
                echo -e 'sampleID' | paste - {output}.header | cat - {output} > {output}.tmp &&
                mv {output}.tmp {output} && rm {output}.header
                """
# --------------------------------------------------------------
rule run_alignment_summary_UMI_start_stop:
        input: BAM_DIR + "/{sample}_mapped.markdup_UMI.bam"
        output:
                "metrics/{sample}.alignment_summary_metrics",
                "metrics/{sample}.insert_size_metrics"
        params:
                java = config["software"]["java"],
                picard_jar = config["software"]["picard_jar"],
                ref = config["reference"]["hg19"]["ref_fa"]
        log: "logs/collect_multiple_metrics/{sample}.log"
        shell:
                "{params.java} -Xmx12g -jar {params.picard_jar} CollectMultipleMetrics VALIDATION_STRINGENCY=LENIENT I={input} O=metrics/{wildcards.sample} REFERENCE_SEQUENCE={params.ref} &> {log}"

# --------------------------------------------------------------
rule merge_hs_metrics_UMI_start_stop:
        input: expand("metrics/{sample}.markdup_UMI.hs_metrics.txt", sample = SAMPLES)
        output: "metrics/all.hs_metrics_UMI_markdup.txt"
        shell:
                """
                grep -v '#' {input[0]} | sed '/^$/d' | head -n 1 | cut -f 2- > {output}.header &&
                for file in {input}; do
                        echo 'Processing file:' ${{file}};
                        grep -v '#' ${{file}} | sed '/^$/d' | sed -n 2p | cut -f 2- >> {output}.tmp;
                done &&
                echo {SAMPLES} | sed 's/ /\\n/g' | paste - {output}.tmp > {output} &&
                echo -e 'sampleID' | paste - {output}.header | cat - {output} > {output}.tmp &&
                mv {output}.tmp {output} && rm {output}.header
                """

rule run_hs_metrics_UMI_start_stop:
        input: BAM_DIR + "/{sample}_mapped.markdup_UMI.bam"
        output:
                hs = "metrics/{sample}.markdup_UMI.hs_metrics.txt",
                int = "metrics/{sample}.markdup_UMI.interval_hs_metrics.txt"
        params:
                java = config["software"]["java"],
                picard_jar = config["software"]["picard_jar"],
                ref = config["reference"]["hg19"]["ref_fa"],
                intervals = "data/interval_list.txt"
        log: "logs/hs_metrics/{sample}_markdup_UMI.log"
        shell:
                "{params.java} -Xmx4g -jar {params.picard_jar} CalculateHsMetrics BAIT_INTERVALS={params.intervals} TARGET_INTERVALS={params.intervals} I={input} O={output.hs} PER_TARGET_COVERAGE={output.int} REFERENCE_SEQUENCE={params.ref} &> {log}"
#--------------------------------------------------------
rule run_flagstats:
        input: BAM_DIR + "/{sample}_mapped.markdup_UMI.bam"
        output: "metrics/{sample}_UMI_markdup.flagstats"
        params:
                samtools = config["software"]["samtools"]
        log: "logs/flagstats/{sample}.log"
        shell:
                "{params.samtools} flagstat {input} > {output} 2> {log}"

#--------------------------------------------------------
 
rule merge_hs_metrics_UMI_error_single:
        input: expand("metrics/{sample}.UMI_error_single.hs_metrics.txt", sample = SAMPLES)
        output: "metrics/all_UMI_error_single.hs_metrics.txt"
        shell:
                """
                grep -v '#' {input[0]} | sed '/^$/d' | head -n 1 | cut -f 2- > {output}.header &&
                for file in {input}; do
                        echo 'Processing file:' ${{file}};
                        grep -v '#' ${{file}} | sed '/^$/d' | sed -n 2p | cut -f 2- >> {output}.tmp;
                done &&
                echo {SAMPLES} | sed 's/ /\\n/g' | paste - {output}.tmp > {output} &&
                echo -e 'sampleID' | paste - {output}.header | cat - {output} > {output}.tmp &&
                mv {output}.tmp {output} && rm {output}.header
                """

rule run_hs_metrics_UMI_error_single:
	input: BAM_DIR + "/{sample}_ss_consensus.mapped.umi_filtered.bam"
        output:
                hs = "metrics/{sample}.UMI_error_single.hs_metrics.txt",
                int = "metrics/{sample}.UMI_error_single.interval_hs_metrics.txt"
	params:
                java = config["software"]["java"],
                picard_jar = config["software"]["picard_jar"],
                ref = config["reference"]["hg19"]["ref_fa"],
                intervals = "data/interval_list.txt"
	log: "logs/hs_metrics/UMI_error_single/{sample}.log"
        shell:
               "{params.java} -Xmx4g -jar {params.picard_jar} CalculateHsMetrics BAIT_INTERVALS={params.intervals} TARGET_INTERVALS={params.intervals} I={input} O={output.hs} PER_TARGET_COVERAGE={output.int} REFERENCE_SEQUENCE={params.ref} &> {log}"

